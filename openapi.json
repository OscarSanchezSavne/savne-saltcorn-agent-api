      },
      "post": {
        "tags": ["Settings"],
        "summary": "Set Saltcorn default locale",
        "operationId": "setLocaleSettings",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LocaleRequest" },
              "examples": {
                "setSpanish": {
                  "value": { "locale": "es", "dry_run": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/GenericOk" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/objects/delete": {
      "post": {
        "tags": ["Maintenance"],
        "summary": "Delete explicitly named objects only",
        "description": "Deletes only explicit page, view, and table names. Wildcards, broad cleanup, and the users table are rejected.",
        "operationId": "deleteObjects",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeleteObjectsRequest" },
              "examples": {
                "dryRun": {
                  "value": {
                    "pages": ["productos"],
                    "views": ["Grid operativo de productos"],
                    "tables": ["productos"],
                    "dry_run": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/GenericOk" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/tables": {
      "post": {
        "tags": ["Schema"],
        "summary": "Create a table and optional fields",
        "operationId": "createTable",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTableRequest" },
              "examples": {
                "productos": {
                  "value": {
                    "name": "productos",
                    "label": "Productos",
                    "fields": [
                      { "name": "codigo", "label": "Codigo", "type": "String", "required": true, "unique": true },
                      { "name": "nombre", "label": "Nombre", "type": "String", "required": true },
                      { "name": "activo", "label": "Activo", "type": "Bool" }
                    ],
                    "dry_run": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/GenericOk" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/fields": {
      "post": {
        "tags": ["Schema"],
        "summary": "Add a field to an existing table",
        "operationId": "addField",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddFieldRequest" }
