{
  "openapi": "3.1.0",
  "info": {
    "title": "Savne Saltcorn Agent API",
    "version": "0.2.53",
    "description": "Authenticated administrative API for operating Saltcorn safely from agents, scripts, and automation tools. All public endpoints are served under /savne-saltcorn-agent-api."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current Saltcorn instance"
    }
  ],
  "security": [
    {
      "SaltcornUserApiToken": []
    }
  ],
  "tags": [
    { "name": "Discovery" },
    { "name": "Settings" },
    { "name": "Schema" },
    { "name": "Data" },
    { "name": "Views" },
    { "name": "Pages" },
    { "name": "Menus" },
    { "name": "Maintenance" }
  ],
  "paths": {
    "/savne-saltcorn-agent-api/openapi.json": {
      "get": {
        "tags": ["Discovery"],
        "summary": "Return this OpenAPI document",
        "operationId": "getOpenApiDocument",
        "security": [],
        "responses": {
          "200": {
            "description": "OpenAPI document",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/docs": {
      "get": {
        "tags": ["Discovery"],
        "summary": "Show browser-friendly OpenAPI documentation",
        "description": "Serves a public HTML page that loads Swagger UI and this plugin's OpenAPI JSON. Administrative operations shown in the contract still require a Saltcorn admin API token.",
        "operationId": "getOpenApiDocs",
        "security": [],
        "responses": {
          "200": {
            "description": "OpenAPI documentation page",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/health": {
      "get": {
        "tags": ["Discovery"],
        "summary": "Check whether the plugin is loaded",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Plugin health",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/commands": {
      "get": {
        "tags": ["Discovery"],
        "summary": "List supported commands",
        "operationId": "commands",
        "responses": {
          "200": {
            "description": "Supported commands",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CommandsResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/state": {
      "get": {
        "tags": ["Discovery"],
        "summary": "Inspect visible Saltcorn state",
        "operationId": "state",
        "responses": {
          "200": { "$ref": "#/components/responses/GenericOk" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/validate": {
      "post": {
        "tags": ["Discovery"],
        "summary": "Validate the access layer",
        "operationId": "validate",
        "requestBody": { "$ref": "#/components/requestBodies/AnyJson" },
        "responses": {
          "200": { "$ref": "#/components/responses/GenericOk" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/viewtemplates": {
      "get": {
        "tags": ["Discovery"],
        "summary": "List available Saltcorn viewtemplates",
        "operationId": "viewtemplates",
        "responses": {
          "200": { "$ref": "#/components/responses/GenericOk" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/fields/capabilities": {
      "get": {
        "tags": ["Discovery"],
        "summary": "List field types, fieldviews, and supported presets",
        "operationId": "fieldCapabilities",
        "responses": {
          "200": { "$ref": "#/components/responses/GenericOk" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/capabilities": {
      "get": {
        "tags": ["Discovery"],
        "summary": "List installed plugins and feature recipe availability",
        "operationId": "capabilities",
        "responses": {
          "200": { "$ref": "#/components/responses/GenericOk" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/capabilities/require": {
      "post": {
        "tags": ["Discovery"],
        "summary": "Require one or more optional feature recipes",
        "operationId": "requireCapabilities",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RequireCapabilitiesRequest" },
              "examples": {
                "advancedViews": {
                  "value": {
                    "features": ["tabulator", "kanban", "calendar", "chart", "attachments", "many_to_many"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/GenericOk" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/savne-saltcorn-agent-api/refresh": {
      "post": {
        "tags": ["Maintenance"],
        "summary": "Refresh Saltcorn caches and notify workers",
        "operationId": "refreshCaches",
